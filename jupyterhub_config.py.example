import os
import shlex

import asyncssh

from jupyterhub.auth import DummyAuthenticator


class PasswordAuthDummyAuthenticator(DummyAuthenticator):
    async def authenticate(self, handler, data):
        username = data.get("username")
        password = data.get("password", "")
        if not username:
            return None
        return {"name": username, "auth_state": {"password": password}}


STORAGE_BASE = "/tmp/jh-test/storage"
HOMES_BASE = os.path.join(STORAGE_BASE, "homes")
SHARED_DOCS = os.path.join(STORAGE_BASE, "shared-docs")
SHARED_DATA = os.path.join(STORAGE_BASE, "shared-data")
SHARED_GROUP = os.path.join(STORAGE_BASE, "shared-selected")


def _ensure_dir(path, mode):
    os.makedirs(path, exist_ok=True)
    os.chmod(path, mode)


async def bootstrap_user_storage(spawner):
    username = spawner.user.name

    _ensure_dir(STORAGE_BASE, 0o755)
    _ensure_dir(HOMES_BASE, 0o755)
    _ensure_dir(SHARED_DOCS, 0o755)
    _ensure_dir(SHARED_DATA, 0o755)
    _ensure_dir(SHARED_GROUP, 0o770)

    if not getattr(spawner, "remote_hosts", None):
        raise RuntimeError("SSHSpawner.remote_hosts must be set")

    remote_host = spawner.remote_hosts[0]
    remote_port = int(getattr(spawner, "remote_port", "22"))
    ssh_kwargs = {}
    if hasattr(spawner, "_ssh_connect_kwargs"):
        ssh_kwargs = spawner._ssh_connect_kwargs(remote_host)

    remote_home = os.path.join(HOMES_BASE, username)
    quoted_home = shlex.quote(remote_home)
    quoted_docs = shlex.quote(SHARED_DOCS)
    quoted_data = shlex.quote(SHARED_DATA)
    quoted_group = shlex.quote(SHARED_GROUP)
    quoted_docs_link = shlex.quote(os.path.join(remote_home, "docs"))
    quoted_data_link = shlex.quote(os.path.join(remote_home, "data"))
    quoted_group_link = shlex.quote(os.path.join(remote_home, "shared-selected"))

    username, password = await spawner.get_auth_credentials()
    remote_script = (
        f"mkdir -p {quoted_home} && chmod 750 {quoted_home} && "
        f"ln -sfn {quoted_docs} {quoted_docs_link} && "
        f"ln -sfn {quoted_data} {quoted_data_link} && "
        f"ln -sfn {quoted_group} {quoted_group_link}"
    )

    async with asyncssh.connect(
        remote_host,
        port=remote_port,
        username=username,
        password=password,
        **ssh_kwargs,
    ) as conn:
        await conn.run(remote_script, check=True)


c.JupyterHub.bind_url = "http://0.0.0.0:8000"
c.ConfigurableHTTPProxy.command = ["/tmp/jh-test/node_modules/.bin/configurable-http-proxy"]
c.JupyterHub.spawner_class = "sshspawner.SSHSpawner"

c.JupyterHub.authenticator_class = PasswordAuthDummyAuthenticator
c.Authenticator.enable_auth_state = True
c.Authenticator.allow_all = True
c.CryptKeeper.keys = ["4e4a54d2e8e7fd1be2f794f29eb6e0268b02f2bc0b0f9d4bd6aa6a0f6a4a9467"]

c.SSHSpawner.remote_hosts = ["localhost"]
c.SSHSpawner.remote_port = "22"
c.SSHSpawner.remote_port_command = '/tmp/jh-test/.venv/bin/python -c "import socket; s=socket.socket(); s.bind((\'127.0.0.1\', 0)); ip, port = s.getsockname(); s.close(); print(f\'{ip} {port}\')"'
c.SSHSpawner.strict_host_key_checking = True
c.SSHSpawner.allow_loopback_no_host_key_checking = True
c.SSHSpawner.path = "/tmp/jh-test/.venv/bin:/usr/local/bin:/usr/bin:/bin"

c.Spawner.default_url = "/lab"
c.Spawner.notebook_dir = "/tmp/jh-test/storage/homes/{username}"
c.Spawner.pre_spawn_hook = bootstrap_user_storage
